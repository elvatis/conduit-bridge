# conduit-bridge .env — copy to `.env` and fill in the keys you use.
#
# Loaded from a `.env` in the directory you run the bridge from, then from
# `~/.conduit/.env`. Real environment variables always take precedence, and an
# earlier file wins over a later one. Keys can also be stored (non-.env) via:
#   conduit-bridge config apiKeys.<provider> <key>

# OpenRouter — enables api-openrouter/* models. Key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Perplexity — enables api-perplexity/* models (sonar* + proxied upstreams)
PERPLEXITY_API_KEY=pplx-...

# Direct API providers (optional — these are also auto-detected from the
# provider's own CLI credentials in ~/.claude, ~/.gemini, ~/.codex)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
# GOOGLE_API_KEY=          # alternative to GEMINI_API_KEY
OPENAI_API_KEY=

# LM Studio server URL (default http://127.0.0.1:1234). No API key needed.
LM_STUDIO_URL=http://127.0.0.1:1234
